# Copy this file to ".env" and fill in the values.

# --- Anthropic (required for real scenario reasoning) ---
# Get a key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-key-here

# --- Database ---
# A MongoDB connection string. Use a local mongod or a free MongoDB Atlas cluster
# (https://www.mongodb.com/atlas). If left blank in development, the server spins
# up a temporary in-memory MongoDB so you can try everything without installing it.
MONGODB_URI=

# --- Auth ---
# Secret used to sign login tokens. Use a long random string in production.
JWT_SECRET=change-me-to-a-long-random-string

# --- Finance data (company search + metric autofill) ---
# Free key at https://site.financialmodelingprep.com/developer/docs
FMP_API_KEY=

# --- Optional ---
PORT=5001
# MODEL=claude-opus-4-8
# MOCK=1              # demo mode: canned estimates/finance, no keys needed
# WEB_SEARCH=0        # disable web-search grounding of scenario reasoning
# WEB_SEARCH_DOMAINS=sec.gov,reuters.com,...   # override the credible-sources allowlist
