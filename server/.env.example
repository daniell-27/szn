# Copy this file to ".env" and fill in the values.

# --- Anthropic (required for real scenario reasoning) ---
# Get a key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-key-here

# --- Database ---
# A MongoDB connection string. Use a local mongod or a free MongoDB Atlas cluster
# (https://www.mongodb.com/atlas). If left blank in development, the server spins
# up a temporary in-memory MongoDB so you can try everything without installing it.
MONGODB_URI=

# --- Auth ---
# Secret used to sign login tokens. Use a long random string in production.
JWT_SECRET=change-me-to-a-long-random-string

# --- Finance data ---
# Hybrid model: fundamentals come from SEC EDGAR (free, primary-source filings);
# FMP supplies company search + market data SEC has no access to (price, market
# cap, P/E, enterprise value) AND powers the earnings-release grounding.
# FMP: free key at https://site.financialmodelingprep.com/developer/docs
FMP_API_KEY=
# SEC EDGAR requires a descriptive User-Agent with a contact address (no key).
SEC_USER_AGENT=SZN valuation app (your-email@example.com)

# --- Fintwit (X/Twitter API) ---
# X recent search is capped at a 7-DAY window on every plan; full archive is
# Enterprise-only (~$42K/mo). For 7-day reach, set X_BEARER_TOKEN.
X_BEARER_TOKEN=
# For ~6-month reach, use a cheaper third-party historical-tweet API instead.
# When FINTWIT_ARCHIVE_KEY is set it is preferred over recent search.
# FINTWIT_ARCHIVE_KEY=
# FINTWIT_ARCHIVE_URL=https://api.twitterapi.io/twitter/tweet/advanced_search
# FINTWIT_LOOKBACK_DAYS=180   # default 180 with an archive key, else 7
# Optional: override the curated account list (comma-separated handles, no @).
# Defaults to server/config/fintwit-accounts.json which you can edit.
# FINTWIT_ACCOUNTS=GavinSBaker,michaeljburry,tsaicapital

# --- Optional ---
PORT=5001
# MODEL=claude-opus-4-8
# MOCK=1              # demo mode: canned estimates/finance, no keys needed
# WEB_SEARCH=0        # disable web-search grounding of scenario reasoning
# WEB_SEARCH_DOMAINS=sec.gov,reuters.com,...   # override the credible-sources allowlist
